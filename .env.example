# Copy this file to .env.local and fill in the value before running `npm run build`.
# .env.local is gitignored (via the *.local pattern) so it will NOT be committed.
#
# The key is used by src/components/MarginRestrictions.tsx to call
# Binance's /sapi/v1/margin/restricted-asset endpoint (MARKET_DATA).
# Use a READ-ONLY, IP-whitelisted key. No secret required.
#
# WARNING: Values of VITE_* variables are baked into the built JS bundle.
# If your GitHub Pages deployment is public, the key will be extractable
# from the client bundle by anyone who loads the page. For a read-only
# MARKET_DATA key the worst case is rate-limit abuse. If that is not
# acceptable, use a serverless proxy instead of baking the key in.
VITE_BINANCE_API_KEY=

# OPTIONAL: Production proxy URL for the Binance SAPI call.
# In dev, Vite proxies /api-binance/* to api.binance.com automatically (see vite.config.ts).
# In production (GitHub Pages is static), the browser cannot call api.binance.com directly
# because Binance does not allow the X-MBX-APIKEY header cross-origin. Set this to the base
# URL of a proxy that forwards to api.binance.com (e.g. a Cloudflare Worker).
# Example: VITE_MARGIN_PROXY=https://my-margin-proxy.example.workers.dev
VITE_MARGIN_PROXY=

# OPTIONAL: Cloudflare Analytics Worker URL (no trailing slash).
# When set, product analytics events (tab switches, macro generations, lookups, etc.)
# are sent here. Leave blank to disable all tracking.
# Example: VITE_ANALYTICS_URL=https://macro-analytics.your-subdomain.workers.dev
VITE_ANALYTICS_URL=
