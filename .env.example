# Copy this file to .env.local and fill in the values before running `npm run build`.
# .env.local is gitignored (via the *.local pattern) so it will NOT be committed.

# ── Cloudflare Worker URL ────────────────────────────────────────────────────
# Required for production: the analytics Worker also acts as a CORS proxy for
# Binance API/FAPI calls (Price Lookup) and Binance SAPI calls (Margin Restrictions).
# The Worker injects BINANCE_API_KEY server-side from a Worker secret — the frontend
# never sees or sends the Binance API key in production.
#
# Set this to your deployed Worker URL (no trailing slash).
# Example: VITE_ANALYTICS_URL=https://macro-analytics.your-subdomain.workers.dev
VITE_ANALYTICS_URL=

# ── Binance API Key (local dev only) ─────────────────────────────────────────
# Only needed for `npm run dev` when testing the Margin Restrictions tab locally.
# In production, VITE_ANALYTICS_URL routes SAPI calls through the Worker which
# injects BINANCE_API_KEY from its secret store — this key is NOT baked into the
# production bundle.
#
# Use a READ-ONLY, MARKET_DATA key. No secret key required.
# WARNING: If VITE_ANALYTICS_URL is NOT set, this value is baked into the built JS
# bundle and is extractable from the page source by anyone.
VITE_BINANCE_API_KEY=

# ── Legacy: explicit margin SAPI proxy URL ───────────────────────────────────
# Deprecated: set VITE_ANALYTICS_URL instead. If both are set, VITE_ANALYTICS_URL
# takes precedence. Kept for backward compatibility.
VITE_MARGIN_PROXY=
